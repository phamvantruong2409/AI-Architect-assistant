{
   "action": {
      "default_icon": {
         "16": "icons/icon-16.png",
         "32": "icons/icon-32.png",
         "48": "icons/icon-48.png"
      },
      "default_popup": "popup.html",
      "default_title": "PromptCard"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": false,
      "exclude_matches": [ "https://accounts.google.com/*", "https://*.accounts.google.com/*", "https://oauth.googleusercontent.com/*", "https://*.oauth.googleusercontent.com/*", "https://checkout.link.com/*", "https://*.checkout.link.com/*", "https://checkout.stripe.com/*", "https://*.checkout.stripe.com/*", "https://buy.stripe.com/*", "https://*.buy.stripe.com/*", "https://billing.stripe.com/*", "https://*.billing.stripe.com/*", "https://pay.stripe.com/*", "https://*.pay.stripe.com/*" ],
      "js": [ "content.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_idle"
   } ],
   "description": "Right-click any image and turn it into detailed prompt analysis in English, Chinese, Japanese, and JSON.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "PromptCard - Image to Prompt AI",
   "permissions": [ "contextMenus", "storage", "scripting", "activeTab", "identity", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.0",
   "web_accessible_resources": [ {
      "matches": [ "http://*/*", "https://*/*" ],
      "resources": [ "icons/history-icon.png" ]
   } ]
}
