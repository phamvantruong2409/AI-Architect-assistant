{
  "name": "ai-architect-assistant",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:electron": "next build && node scripts/prepare-electron.js",
    "dist": "npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.108.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "pdf-parse": "^1.1.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.aiarchitect.assistant",
    "productName": "AI Architect Assistant",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
