{
  "name": "ai-architect-assistant",
  "version": "0.5.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fetch:realesrgan": "node scripts/fetch-realesrgan.js",
    "build:electron": "next build && node scripts/prepare-electron.js",
    "predist": "npm run build:electron",
    "dist": "electron-builder",
    "release": "npm run build:electron && electron-builder --publish always"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "canvas-confetti": "^1.9.4",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "pdf-parse": "^1.1.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.aiarchitect.assistant",
    "productName": "AI Architect Assistant",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": "vendor/realesrgan",
        "to": "realesrgan"
      }
    ],
    "protocols": [
      {
        "name": "AI Architect Assistant",
        "schemes": [
          "aiarchitect"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "phamvantruong2409",
        "repo": "AI-Architect-assistant"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "AI Architect Assistant",
      "include": "build/installer.nsh"
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
